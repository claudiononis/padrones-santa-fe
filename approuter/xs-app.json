{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "padones-santa-fe-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/pricing/(.*)$",
      "target": "/$1",
      "destination": "S4HANA-PRICING",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "S4HANA-BP",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/s4/(.*)$",
      "target": "/$1",
      "destination": "S4HANA-BP",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "target": "padonessantafe/$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
