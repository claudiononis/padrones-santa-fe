<mvc:View
  controllerName="padones.santa.fe.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  xmlns:unified="sap.ui.unified">
  <f:DynamicPage id="dynamicPage" class="sapUiSizeCompact">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Padrón Santa Fe - Percepciones IIBB" level="H1"/>
        </f:heading>
        <f:expandedContent>
          <ObjectStatus
            text="{= ${app>/jobStatus} ? ${app>/jobStatus} : 'Listo para cargar el padrón de percepciones' }"
            state="{= ${app>/jobStatus} === 'FINALIZADO' ? 'Success' : ${app>/jobStatus} === 'ERROR' ? 'Error' : 'Information' }"/>
        </f:expandedContent>
        <f:snappedContent>
          <Text text="Carga y procesamiento de alícuotas de percepción"/>
        </f:snappedContent>
        <f:actions>
          <Button icon="sap-icon://refresh" text="Limpiar" press=".onClear"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <VBox class="sfHeaderContent">
          <MessageStrip
            text="Subí el archivo mensual del padrón de percepciones de Santa Fe. Se calculará la alícuota SAP según el tipo de contribuyente: C divide por 2, D conserva la alícuota original."
            type="Information"
            showIcon="true"
            class="sapUiSmallMarginBottom"/>

          <HBox wrap="Wrap" alignItems="End" justifyContent="SpaceBetween">
            <HBox wrap="Wrap" alignItems="End">
              <VBox class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                <Label text="Archivo del padrón" labelFor="fileUploader"/>
                <unified:FileUploader
                  id="fileUploader"
                  width="24rem"
                  sameFilenameAllowed="true"
                  fileType="txt,csv"
                  change=".onFileChange"
                placeholder="Seleccionar archivo de percepciones"/>
              </VBox>
              <Button
                text="Preparar carga"
                icon="sap-icon://upload-to-cloud"
                type="Emphasized"
                enabled="{= ${app>/validRows} > 0 }"
                press=".onPrepareUpload"
                class="sapUiTinyMarginBottom"/>
            </HBox>
            <HBox wrap="Wrap" class="sfKpiStrip">
              <VBox class="sfKpiItem sapUiTinyMarginBegin sapUiTinyMarginBottom">
                <Label text="Líneas"/>
                <ObjectNumber number="{app>/totalRows}" state="Information"/>
              </VBox>
              <VBox class="sfKpiItem sapUiTinyMarginBegin sapUiTinyMarginBottom">
                <Label text="Válidos"/>
                <ObjectNumber number="{app>/validRows}" state="Success"/>
              </VBox>
              <VBox class="sfKpiItem sapUiTinyMarginBegin sapUiTinyMarginBottom">
                <Label text="Advertencias"/>
                <ObjectNumber number="{app>/warningRows}" state="Warning"/>
              </VBox>
              <VBox class="sfKpiItem sapUiTinyMarginBegin sapUiTinyMarginBottom">
                <Label text="Errores"/>
                <ObjectNumber number="{app>/errorRows}" state="Error"/>
              </VBox>
            </HBox>
          </HBox>
        </VBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <VBox class="sfContent sapUiResponsiveContentPadding">
        <IconTabBar expandable="false" class="sapUiNoContentPadding">
          <items>
            <IconTabFilter text="Registros" icon="sap-icon://table-view" count="{app>/validRows}">
              <VBox class="sfResultCard">
                <OverflowToolbar class="sfResultToolbar">
                  <Title text="Resultados de validación" level="H2"/>
                  <ToolbarSpacer/>
                  <ObjectStatus
                    text="{= ${app>/validRows} + ' listos para procesar' }"
                    state="Success"
                    icon="sap-icon://sys-enter-2"/>
                </OverflowToolbar>

                <MessageStrip
                  text="La alícuota SAP se calcula automáticamente: tipo C divide la alícuota original por 2; tipo D conserva el valor original."
                  type="Information"
                  showIcon="true"
                  class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

                <ScrollContainer
                  height="34rem"
                  vertical="true"
                  horizontal="false"
                  focusable="true"
                  class="sfTableScroll">
                  <Table
                    id="recordsTable"
                    mode="None"
                    sticky="ColumnHeaders"
                    alternateRowColors="true"
                    growing="true"
                    growingScrollToLoad="true"
                    growingThreshold="50"
                    items="{app>/rows}"
                    noDataText="Cargá un archivo del padrón para ver los registros válidos.">
                    <columns>
                      <Column>
                        <Text text="Contribuyente"/>
                      </Column>
                      <Column width="8rem">
                        <Text text="CUIT"/>
                      </Column>
                      <Column width="7rem" hAlign="Center">
                        <Text text="Tipo"/>
                      </Column>
                      <Column width="10rem" hAlign="End">
                        <Text text="Alícuota Original"/>
                      </Column>
                      <Column width="9rem" hAlign="End">
                        <Text text="Alícuota SAP"/>
                      </Column>
                      <Column width="8rem" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Cliente SAP"/>
                      </Column>
                    </columns>
                    <items>
                      <ColumnListItem
                        type="Inactive"
                        highlight="{= ${app>taxpayerType} === 'C' ? 'Warning' : 'Success' }">
                        <cells>
                          <ObjectIdentifier
                            title="{app>companyName}"
                            text="{= ${app>businessPartner} ? 'BP ' + ${app>businessPartner} : 'Business Partner validado' }"/>
                          <Text text="{app>cuit}"/>
                          <ObjectStatus
                            text="{= ${app>taxpayerType} === 'C' ? 'Tipo C' : 'Tipo D' }"
                            state="{= ${app>taxpayerType} === 'C' ? 'Warning' : 'Success' }"/>
                          <ObjectNumber number="{app>originalRate}" unit="%"/>
                          <ObjectNumber
                            number="{app>rate}"
                            unit="%"
                            state="{= ${app>taxpayerType} === 'C' ? 'Warning' : 'Success' }"
                            emphasized="true"/>
                          <Text text="{app>customer}"/>
                        </cells>
                      </ColumnListItem>
                    </items>
                  </Table>
                </ScrollContainer>
              </VBox>
            </IconTabFilter>

            <IconTabFilter text="Log" icon="sap-icon://message-popup">
              <List
                items="{app>/messages}"
                noDataText="Sin mensajes."
                class="sfMessageList">
                <CustomListItem>
                  <MessageStrip
                    text="{app>text}"
                    type="{app>type}"
                    showIcon="true"
                    class="sapUiTinyMargin"/>
                </CustomListItem>
              </List>
            </IconTabFilter>
          </items>
        </IconTabBar>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
