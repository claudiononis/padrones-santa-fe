<mvc:View
  controllerName="padones.santa.fe.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:unified="sap.ui.unified">
  <VBox class="sfOriginalPage">
    <HBox alignItems="Center" justifyContent="SpaceBetween" class="sfOriginalTitleRow">
      <VBox>
        <Title text="Padrón Santa Fe - Percepciones IIBB" level="H1"/>
        <ObjectStatus
          text="{= ${app>/jobStatus} ? ${app>/jobStatus} : 'Listo para cargar el padrón de percepciones' }"
          state="{= ${app>/jobStatus} === 'FINALIZADO' ? 'Success' : ${app>/jobStatus} === 'ERROR' ? 'Error' : 'Information' }"/>
      </VBox>
      <Button icon="sap-icon://refresh" text="Limpiar" press=".onClear"/>
    </HBox>

    <HBox wrap="Wrap" alignItems="Center" class="sfOriginalUploadRow">
      <Label text="Archivo" labelFor="fileUploader" class="sapUiTinyMarginEnd"/>
      <unified:FileUploader
        id="fileUploader"
        width="24rem"
        sameFilenameAllowed="true"
        fileType="txt,csv"
        change=".onFileChange"
        placeholder="Seleccionar archivo de percepciones"
        class="sapUiSmallMarginEnd"/>
      <Button
        text="Preparar carga"
        icon="sap-icon://upload-to-cloud"
        type="Emphasized"
        enabled="{= ${app>/validRows} > 0 }"
        press=".onPrepareUpload"/>
    </HBox>

    <HBox wrap="Wrap" alignItems="Center" class="sfOriginalStatusRow">
      <VBox
        alignItems="Center"
        class="{= ${app>/activeSection} === 'records' ? 'sfSectionTile sfSectionTileActive' : 'sfSectionTile' }">
        <Button
          icon="sap-icon://table-view"
          type="{= ${app>/activeSection} === 'records' ? 'Emphasized' : 'Transparent' }"
          class="sfSectionTileIcon"
          press=".onShowRecords"/>
        <Text text="{app>/validRows}" class="sfSectionTileCount"/>
        <Text text="Registros" class="sfSectionTileLabel"/>
      </VBox>
      <VBox
        alignItems="Center"
        class="{= ${app>/activeSection} === 'log' ? 'sfSectionTile sfSectionTileActive' : 'sfSectionTile' }">
        <Button
          icon="sap-icon://message-popup"
          type="{= ${app>/activeSection} === 'log' ? 'Emphasized' : 'Transparent' }"
          class="sfSectionTileIcon"
          press=".onShowLog"/>
        <Text text="{= ${app>/messages}.length }" class="sfSectionTileCount"/>
        <Text text="Log" class="sfSectionTileLabel"/>
      </VBox>
      <VBox alignItems="Center" class="sfSectionTile sfSectionTileReadonly">
        <Button
          icon="sap-icon://document-text"
          enabled="false"
          type="Transparent"
          class="sfSectionTileIcon"/>
        <Text text="{app>/totalRows}" class="sfSectionTileCount"/>
        <Text text="Líneas" class="sfSectionTileLabel"/>
      </VBox>
      <VBox alignItems="Center" class="sfSectionTile sfSectionTileReadonly">
        <Button
          icon="sap-icon://create"
          enabled="false"
          type="Transparent"
          class="sfSectionTileIcon"/>
        <Text text="{app>/createdCount}" class="sfSectionTileCount"/>
        <Text text="Creados" class="sfSectionTileLabel"/>
      </VBox>
      <VBox alignItems="Center" class="sfSectionTile sfSectionTileReadonly">
        <Button
          icon="sap-icon://edit"
          enabled="false"
          type="Transparent"
          class="sfSectionTileIcon"/>
        <Text text="{app>/updatedCount}" class="sfSectionTileCount"/>
        <Text text="Actualiza..." class="sfSectionTileLabel"/>
      </VBox>
      <VBox alignItems="Center" class="sfSectionTile sfSectionTileReadonly">
        <Button
          icon="sap-icon://error"
          enabled="false"
          type="Transparent"
          class="sfSectionTileIcon"/>
        <Text text="{app>/processedErrorCount}" class="sfSectionTileCount"/>
        <Text text="Errores" class="sfSectionTileLabel"/>
      </VBox>
      <VBox alignItems="Center" class="sfSectionTile sfSectionTileReadonly sfSectionTileWide">
        <Button
          icon="sap-icon://activity-individual"
          enabled="false"
          type="Transparent"
          class="sfSectionTileIcon"/>
        <Text text="{= ${app>/jobStatus} ? ${app>/jobStatus} : 'Sin proce...' }" class="sfSectionTileLabel"/>
      </VBox>
    </HBox>

    <VBox visible="{= ${app>/activeSection} === 'records' }" class="sfOriginalPanel">
      <OverflowToolbar>
        <Title text="Registros listos para procesar" level="H2"/>
        <ToolbarSpacer/>
        <ObjectStatus
          text="{= ${app>/validRows} + ' registros válidos' }"
          state="Success"
          icon="sap-icon://sys-enter-2"/>
      </OverflowToolbar>
      <ScrollContainer height="24rem" vertical="true" horizontal="false" focusable="true">
        <Table
          id="recordsTable"
          mode="None"
          sticky="ColumnHeaders"
          growing="true"
          growingThreshold="50"
          items="{app>/rows}"
          noDataText="Cargá un archivo del padrón para ver los registros válidos.">
          <columns>
            <Column width="9rem">
              <Text text="CUIT"/>
            </Column>
            <Column width="6rem" hAlign="Center">
              <Text text="Tipo"/>
            </Column>
            <Column width="9rem" hAlign="End">
              <Text text="Alícuota Original"/>
            </Column>
            <Column width="9rem" hAlign="End">
              <Text text="Alícuota SAP"/>
            </Column>
            <Column width="8rem">
              <Text text="Cliente SAP"/>
            </Column>
            <Column minScreenWidth="Tablet" demandPopin="true">
              <Text text="Razón Social"/>
            </Column>
          </columns>
          <items>
            <ColumnListItem type="Inactive">
              <cells>
                <ObjectIdentifier title="{app>cuit}" text="{= ${app>businessPartner} ? 'BP ' + ${app>businessPartner} : ${app>customer} ? 'Cliente ' + ${app>customer} : '' }"/>
                <ObjectStatus
                  text="{app>taxpayerType}"
                  state="{= ${app>taxpayerType} === 'C' ? 'Warning' : 'Success' }"/>
                <ObjectNumber number="{app>originalRate}" unit="%"/>
                <ObjectNumber number="{app>rate}" unit="%" emphasized="true"/>
                <Text text="{app>customer}"/>
                <Text text="{app>companyName}" wrapping="false"/>
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </ScrollContainer>
    </VBox>

    <VBox visible="{= ${app>/activeSection} === 'log' }" class="sfOriginalPanel">
      <OverflowToolbar>
        <Title text="Registro de actividad" level="H2"/>
        <ToolbarSpacer/>
        <ObjectStatus
          text="{= ${app>/messages}.length + ' eventos' }"
          state="Information"
          icon="sap-icon://activity-items"/>
      </OverflowToolbar>
      <ScrollContainer height="18rem" vertical="true" horizontal="false" focusable="true">
        <List items="{app>/messages}" noDataText="Sin mensajes.">
          <CustomListItem>
            <MessageStrip
              text="{app>text}"
              type="{app>type}"
              showIcon="true"
              class="sapUiTinyMargin"/>
          </CustomListItem>
        </List>
      </ScrollContainer>
    </VBox>
  </VBox>
</mvc:View>
