<mvc:View
  controllerName="padones.santa.fe.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:unified="sap.ui.unified">
  <VBox class="sfOriginalPage">
    <f:ShellBar
      title="Padrón Santa Fe - Percepciones IIBB"
      showCopilot="false"
      showProductSwitcher="false"/>

    <VBox class="sfPageBody">
    <HBox alignItems="Center" justifyContent="SpaceBetween" class="sfOriginalTitleRow">
      <ObjectStatus
        text="{= ${app>/jobStatus} ? ${app>/jobStatus} : 'Listo para cargar el padrón de percepciones' }"
        state="{= ${app>/jobStatus} === 'FINALIZADO' ? 'Success' : ${app>/jobStatus} === 'ERROR' ? 'Error' : 'Information' }"/>
      <Button icon="sap-icon://refresh" text="Limpiar" press=".onClear"/>
    </HBox>

    <HBox wrap="Wrap" alignItems="Center" class="sfOriginalUploadRow">
      <Label text="Archivo" labelFor="fileUploader" class="sapUiTinyMarginEnd"/>
      <unified:FileUploader
        id="fileUploader"
        width="24rem"
        sameFilenameAllowed="true"
        fileType="txt,csv"
        change=".onFileChange"
        placeholder="Seleccionar archivo de percepciones"
        class="sapUiSmallMarginEnd"/>
      <Button
        text="Preparar carga"
        icon="sap-icon://upload-to-cloud"
        type="Emphasized"
        enabled="{= ${app>/validRows} > 0 }"
        press=".onPrepareUpload"/>
    </HBox>

    <HBox wrap="Wrap" alignItems="Center" class="sfOriginalStatusRow">
      <Button
        icon="sap-icon://table-view"
        text="{= ${app>/validRows} + ' registros' }"
        type="{= ${app>/activeSection} === 'records' ? 'Emphasized' : 'Transparent' }"
        class="sfKpiCardButton"
        press=".onShowRecords"/>
      <Button
        icon="sap-icon://message-popup"
        text="{= ${app>/messages}.length + ' eventos' }"
        type="{= ${app>/activeSection} === 'log' ? 'Emphasized' : 'Transparent' }"
        class="sfKpiCardButton"
        press=".onShowLog"/>
      <VBox class="sfKpiMiniCard">
        <ObjectStatus icon="sap-icon://document-text" text="{app>/totalRows}" state="Information"/>
        <Text text="Líneas"/>
      </VBox>
      <VBox class="sfKpiMiniCard">
        <ObjectStatus icon="sap-icon://create" text="{app>/createdCount}" state="Success"/>
        <Text text="Creados"/>
      </VBox>
      <VBox class="sfKpiMiniCard">
        <ObjectStatus icon="sap-icon://edit" text="{app>/updatedCount}" state="Information"/>
        <Text text="Actualizados"/>
      </VBox>
      <VBox class="sfKpiMiniCard">
        <ObjectStatus
          icon="sap-icon://error"
          text="{app>/processedErrorCount}"
          state="{= ${app>/processedErrorCount} > 0 ? 'Error' : 'Success' }"/>
        <Text text="Errores"/>
      </VBox>
      <VBox class="sfKpiMiniCard sfKpiStatusCard">
        <ObjectStatus
          icon="sap-icon://activity-individual"
          text="{= ${app>/jobStatus} ? ${app>/jobStatus} : 'Sin procesar' }"
          state="{= ${app>/jobStatus} === 'FINALIZADO' ? 'Success' : ${app>/jobStatus} === 'FINALIZADO_CON_ERRORES' ? 'Warning' : ${app>/jobStatus} === 'ERROR' ? 'Error' : 'Information' }"/>
        <Text text="Estado"/>
      </VBox>
    </HBox>

    <VBox visible="{= ${app>/activeSection} === 'records' }" class="sfOriginalPanel">
      <OverflowToolbar>
        <Title text="Registros listos para procesar" level="H2"/>
        <ToolbarSpacer/>
        <ObjectStatus
          text="{= ${app>/validRows} + ' registros válidos' }"
          state="Success"
          icon="sap-icon://sys-enter-2"/>
      </OverflowToolbar>
      <ScrollContainer height="24rem" vertical="true" horizontal="false" focusable="true">
        <Table
          id="recordsTable"
          mode="None"
          sticky="ColumnHeaders"
          growing="true"
          growingThreshold="50"
          items="{app>/rows}"
          noDataText="Cargá un archivo del padrón para ver los registros válidos.">
          <columns>
            <Column width="9rem">
              <Text text="CUIT"/>
            </Column>
            <Column width="6rem" hAlign="Center">
              <Text text="Tipo"/>
            </Column>
            <Column width="9rem" hAlign="End">
              <Text text="Alícuota Original"/>
            </Column>
            <Column width="9rem" hAlign="End">
              <Text text="Alícuota SAP"/>
            </Column>
            <Column width="8rem">
              <Text text="Cliente SAP"/>
            </Column>
            <Column minScreenWidth="Tablet" demandPopin="true">
              <Text text="Razón Social"/>
            </Column>
          </columns>
          <items>
            <ColumnListItem type="Inactive">
              <cells>
                <ObjectIdentifier title="{app>cuit}" text="{= ${app>businessPartner} ? 'BP ' + ${app>businessPartner} : ${app>customer} ? 'Cliente ' + ${app>customer} : '' }"/>
                <ObjectStatus
                  text="{app>taxpayerType}"
                  state="{= ${app>taxpayerType} === 'C' ? 'Warning' : 'Success' }"/>
                <ObjectNumber number="{app>originalRate}" unit="%"/>
                <ObjectNumber number="{app>rate}" unit="%" emphasized="true"/>
                <Text text="{app>customer}"/>
                <Text text="{app>companyName}" wrapping="false"/>
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </ScrollContainer>
    </VBox>

    <VBox visible="{= ${app>/activeSection} === 'log' }" class="sfOriginalPanel">
      <OverflowToolbar>
        <Title text="Registro de actividad" level="H2"/>
        <ToolbarSpacer/>
        <ObjectStatus
          text="{= ${app>/messages}.length + ' eventos' }"
          state="Information"
          icon="sap-icon://activity-items"/>
      </OverflowToolbar>
      <ScrollContainer height="18rem" vertical="true" horizontal="false" focusable="true">
        <List items="{app>/messages}" noDataText="Sin mensajes.">
          <CustomListItem>
            <MessageStrip
              text="{app>text}"
              type="{app>type}"
              showIcon="true"
              class="sapUiTinyMargin"/>
          </CustomListItem>
        </List>
      </ScrollContainer>
    </VBox>
    </VBox>
  </VBox>
</mvc:View>
